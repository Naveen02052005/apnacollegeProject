<%- layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <br><br>
        <h3>Create a New List</h3>

        <!-- We used bootstrap for validation and we used novalidate to avoid default validation(required) so for this we need to paste script code also from bootstrap website and we also need to use required for all inputs and for script i kept link in boilerplate code -->

        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data"> <!-- enctype is to send files to backend-->
            <div>
                <label for="title" class="form-label">Title</label>
                <input name="listing[title]" type="text" placeholder="Add a Catchy title" class="form-control" required>
                <div class="valid-feedback">Title looks good</div> <!-- this is bootstrap div for if we enter valid name then it shows "Title looks good"-->
            </div>

            <br><br>

            <div>
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control" required></textarea>
                <div class="invalid-feedback">Please enter a short description</div> <!-- this is bootstrap div for if we enter any description then it shows "Please enter a short descriptin"-->
            </div>

            <br><br>

            <!-- <div>
                <label for="image" class="form-label">Image Link</label>
                <input name="listing[image]" type="text" placeholder="Enter image URL/Link" class="form-control" >
            </div> -->
            <div>
                <label for="image" class="form-label">Upload Listing Image</label>
                <input name="listing[image]" type="file" placeholder="Enter image URL/Link" class="form-control"required >
            </div>
            <br><br>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input name="listing[price]"  placeholder="1200" class="form-control" required>
                    <div class="invalid-feedback">Price should be valid</div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" type="text" placeholder="India" class="form-control" required>
                    <div class="invalid-feedback">Country name should be valid</div>
                </div>
            </div>

            <div>
                <label for="location" class="form-label">Location</label>
                <input name="listing[location]" type="text" placeholder="Telangana, Ramagundam" class="form-control" required>
                <div class="invalid-feedback">Location should be valid</div>
            </div>


            <button class="btn btn-dark add-btn mt-3">Add</button>
        </form>
    </div>

    <br><br>
</div>

